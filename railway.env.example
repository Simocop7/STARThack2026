# Railway environment variables
# Set these in your Railway project dashboard under Variables

AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ElevenLabs TTS (optional — enables voice)
ELEVENLABS_API_KEY=

# CORS — set to * to allow all origins (required for Railway HTTPS deploy)
CORS_ORIGINS=*

# Rate limiting (increase for demo if needed)
RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_WINDOW_SECONDS=60
